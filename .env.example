# --- Backend (Render) ---
# NODE_ENV=production
# PORT=10000
# MONGODB_URI=mongodb+srv://...
# JWT_SECRET=...
# JWT_EXPIRE=7d
# CLIENT_URL=https://your-app.vercel.app
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:you@example.com

# --- Frontend (Vercel build-time) ---
